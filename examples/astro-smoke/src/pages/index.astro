---
import Counter from '../components/Counter.jsx'
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Sygnal Astro Smoke Test</title>
    <style>
      :root {
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
      }
      body {
        margin: 2rem;
      }
      .counter {
        max-width: 320px;
        padding: 1rem;
        border: 1px solid #ccc;
        border-radius: 8px;
      }
      button {
        padding: 0.5rem 0.75rem;
      }
    </style>
  </head>
  <body>
    <h1>Sygnal + Astro Plugin Test</h1>
    <Counter title="Plugin Smoke Test" client:load />
  </body>
</html>
